<%- include('../partials/header') %>

<section class="event-hero">
  <div class="event-hero-overlay">
    <div class="container">
      <h1>Sports Events</h1>
      <p><a href="/">Home</a> / Sports Events</p>
    </div>
  </div>
</section>

<section class="event-intro-section">
  <div class="container">
    <p>
      Sports activities at our school encourage discipline, teamwork, confidence,
      fitness and healthy competition among students.
    </p>
  </div>
</section>

<section class="event-list-section">
  <div class="container">

    <% if (events && events.length > 0) { %>

      <% events.forEach(event => { %>
        <div class="event-showcase-card">

          <div class="event-photo">
            <img src="<%= event.image %>" alt="<%= event.title %>">
          </div>

          <div class="event-details">
            <h2><%= event.title %></h2>
            <div class="event-line"></div>

            <div class="event-description">
              <%- event.description %>
            </div>

            <div class="event-date">
              📅 <%= new Date(event.date).toDateString() %>
            </div>
          </div>

        </div>
      <% }) %>

    <% } else { %>
      <div class="no-events">
        <h2>No events added yet.</h2>
        <p>Please add event details from MongoDB.</p>
      </div>
    <% } %>

  </div>
</section>

<style>
.event-hero{
  height:360px;
  background:url('/images/events/event-bg.jpg') center/cover no-repeat;
}

.event-hero-overlay{
  height:100%;
  background:rgba(0,33,71,0.65);
  display:flex;
  align-items:center;
}

.event-hero h1{
  color:#fff;
  font-size:56px;
  font-weight:800;
  margin-bottom:12px;
}

.event-hero p{
  color:#fff;
  font-size:18px;
}

.event-hero a{
  color:#ffc400;
  text-decoration:none;
}

.container{
  width:86%;
  margin:auto;
}

.event-intro-section{
  padding:70px 0 30px;
  background:#fff;
}

.event-intro-section p{
  max-width:950px;
  font-size:20px;
  line-height:1.8;
  color:#333;
}

.event-list-section{
  padding:40px 0 80px;
  background:#fff;
}

.event-showcase-card{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:35px;
  background:#fff;
  margin-bottom:45px;
  padding:18px;
  box-shadow:0 6px 22px rgba(0,0,0,0.12);
  border-radius:6px;
}

.event-photo img{
  width:100%;
  height:360px;
  object-fit:cover;
}

.event-details{
  padding:20px 10px;
}

.event-details h2{
  font-size:34px;
  color:#002147;
  margin-bottom:14px;
}

.event-line{
  width:70px;
  height:4px;
  background:#ffc400;
  margin-bottom:24px;
}

.event-description{
  font-size:18px;
  line-height:1.8;
  color:#333;
  text-align:justify;
}

.event-date{
  margin-top:30px;
  font-size:22px;
  color:#002147;
  font-weight:700;
}

.no-events{
  text-align:center;
  padding:60px;
  background:#f5f5f5;
  border-radius:8px;
}

.no-events h2{
  color:#002147;
}

@media(max-width:900px){
  .event-showcase-card{
    grid-template-columns:1fr;
  }

  .event-hero h1{
    font-size:40px;
  }

  .event-photo img{
    height:260px;
  }
}
</style>

<%- include('../partials/footer') %>