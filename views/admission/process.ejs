<%- include('../partials/header') %>

<section class="admission-hero">
  <div class="admission-overlay">
    <div class="admission-container">
      <h1>Admission Process</h1>
      <p><a href="/">Home</a> / Admission Process</p>
    </div>
  </div>
</section>

<section class="admission-process-section">
  <div class="admission-container">

    <div class="section-heading">
      <h2>Your Journey Starts Here</h2>
      <p>Our admission process is simple, transparent and designed to help parents complete every step smoothly.</p>
    </div>

    <div class="process-timeline">

      <div class="process-card">
        <span>01</span>
        <h3>Enquiry</h3>
        <p>Parents submit an enquiry form or contact the school admission office.</p>
      </div>

      <div class="process-card">
        <span>02</span>
        <h3>School Visit</h3>
        <p>Parents may visit the campus and understand academics, facilities and environment.</p>
      </div>

      <div class="process-card">
        <span>03</span>
        <h3>Registration</h3>
        <p>Fill the registration form with student and parent details.</p>
      </div>

      <div class="process-card">
        <span>04</span>
        <h3>Document Verification</h3>
        <p>Submit required documents for verification by the admission team.</p>
      </div>

      <div class="process-card">
        <span>05</span>
        <h3>Interaction</h3>
        <p>Student and parent interaction is conducted as per class requirement.</p>
      </div>

      <div class="process-card">
        <span>06</span>
        <h3>Admission Confirmation</h3>
        <p>Admission is confirmed after approval and fee submission.</p>
      </div>

    </div>

  </div>
</section>

<section class="admission-cta">
  <div class="admission-container">
    <h2>Ready to Apply?</h2>
    <p>Start your child’s learning journey with us today.</p>
    <a href="/admission/registration">Register Now</a>
  </div>
</section>

<%- include('../partials/footer') %>