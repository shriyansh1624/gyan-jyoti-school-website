<%- include('../partials/header') %>

<section class="admission-hero">
  <div class="admission-overlay">
    <div class="admission-container">
      <h1>Guidelines & Policies</h1>
      <p><a href="/">Home</a> / Guidelines & Policies</p>
    </div>
  </div>
</section>

<section class="guidelines-section">
  <div class="admission-container">

    <div class="section-heading">
      <h2>Admission Guidelines</h2>
      <p>Please read the important admission guidelines before applying.</p>
    </div>

    <div class="guidelines-grid">

      <div class="guideline-card">
        <h3>Required Documents</h3>
        <p>Birth certificate, previous school report card, transfer certificate, Aadhaar card and passport size photographs may be required.</p>
      </div>

      <div class="guideline-card">
        <h3>Age Criteria</h3>
        <p>Admission is granted according to age eligibility and class standards as per school norms.</p>
      </div>

      <div class="guideline-card">
        <h3>Interaction</h3>
        <p>Student interaction or assessment may be conducted depending on the class applied for.</p>
      </div>

      <div class="guideline-card">
        <h3>Fee Submission</h3>
        <p>Admission will be confirmed only after successful document verification and fee payment.</p>
      </div>

      <div class="guideline-card">
        <h3>Discipline Policy</h3>
        <p>Students are expected to follow school discipline, uniform rules and code of conduct.</p>
      </div>

      <div class="guideline-card">
        <h3>Final Decision</h3>
        <p>The school admission committee reserves the final decision regarding admission approval.</p>
      </div>

    </div>

  </div>
</section>

