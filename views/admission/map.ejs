<%- include('../partials/header') %>

<section class="school-map-hero">
  <div class="map-container">
    <img src="/images/logo.png" class="map-logo" alt="Gyan Jyoti Logo">
    <span class="map-badge">Visit Our Campus</span>
    <h1>Map of School</h1>
    <p>Find Gyan Jyoti English Medium School easily with address, route and location details.</p>
  </div>
</section>

<section class="location-section">
  <div class="location-wrapper">

    <div class="location-info">
      <span class="section-tag">School Location</span>
      <h2>Gyan Jyoti English Medium School</h2>

      <div class="address-card">
        <i class="fas fa-location-dot"></i>
        <div>
          <h3>Complete Address</h3>
          <p>
            C4M4+858, Ruchika Catering Rd,<br>
            North Civil Lines,<br>
            Nainpur, Madhya Pradesh 481776
          </p>
        </div>
      </div>

      <div class="route-info">
        <div>
          <i class="fas fa-route"></i>
          <h4>Easy Route</h4>
          <p>Use Google Maps for accurate directions to the school campus.</p>
        </div>

        <div>
          <i class="fas fa-clock"></i>
          <h4>Office Timing</h4>
          <p>Mon - Fri: 8:00 AM - 4:00 PM<br>Sat: 9:00 AM - 1:00 PM</p>
        </div>

        <div>
          <i class="fas fa-phone"></i>
          <h4>School Phone</h4>
          <p>+91 98765-43210</p>
        </div>
      </div>

      <a
        href="https://www.google.com/maps/search/?api=1&query=C4M4+858+Ruchika+Catering+Rd+North+Civil+Lines+Nainpur+Madhya+Pradesh+481776"
        target="_blank"
        class="direction-btn">
        <i class="fas fa-location-arrow"></i> Open Direction in Google Maps
      </a>
    </div>

    <div class="map-panel">
      <div class="map-header">
        <h3><i class="fas fa-map-marked-alt"></i> Live Location Map</h3>
        <span>Nainpur, Madhya Pradesh</span>
      </div>

      <iframe
        src="https://maps.google.com/maps?q=C4M4+858,+Ruchika+Catering+Rd,+North+Civil+Lines,+Nainpur,+Madhya+Pradesh+481776&t=&z=17&ie=UTF8&iwloc=&output=embed"
        loading="lazy">
      </iframe>
    </div>

  </div>
</section>

<section class="campus-guide-section">
  <div class="map-container">

    <div class="guide-heading">
      <span class="section-tag">Campus Visit Guide</span>
      <h2>Before You Visit</h2>
      <p>Helpful information for parents and visitors coming to the school campus.</p>
    </div>

    <div class="guide-grid">
      <div class="guide-card">
        <i class="fas fa-id-card"></i>
        <h3>Carry Basic Details</h3>
        <p>Parents may carry student details for admission or enquiry support.</p>
      </div>

      <div class="guide-card">
        <i class="fas fa-user-tie"></i>
        <h3>Meet School Office</h3>
        <p>Visit the office for admission, fees, documents and school information.</p>
      </div>

      <div class="guide-card">
        <i class="fas fa-calendar-check"></i>
        <h3>Best Visit Time</h3>
        <p>Visit during school office hours for quick and proper guidance.</p>
      </div>
    </div>

  </div>
</section>

<style>
  .map-container {
    width: 86%;
    max-width: 1200px;
    margin: auto;
  }

  .school-map-hero {
    min-height: 500px;
    background:
      linear-gradient(rgba(0,31,63,.84), rgba(0,31,63,.84)),
      url('/images/school-bg.jpg');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .school-map-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,195,0,.35) 2px, transparent 2px),
      radial-gradient(circle, rgba(255,255,255,.14) 1px, transparent 1px);
    background-size: 120px 120px, 75px 75px;
    animation: mapDots 22s linear infinite;
  }

  @keyframes mapDots {
    from { transform: translateY(0); }
    to { transform: translateY(-120px); }
  }

  .school-map-hero .map-container {
    position: relative;
    z-index: 2;
  }

  .map-logo {
    width: 125px;
    height: 125px;
    object-fit: contain;
    background: white;
    padding: 8px;
    border-radius: 50%;
    border: 5px solid #ffc300;
    box-shadow: 0 18px 45px rgba(0,0,0,.35);
    margin-bottom: 18px;
  }

  .map-badge,
  .section-tag {
    display: inline-block;
    background: #ffc300;
    color: #001f3f;
    padding: 9px 22px;
    border-radius: 40px;
    font-weight: 900;
    margin-bottom: 15px;
  }

  .school-map-hero h1 {
    color: white;
    font-size: 66px;
    font-weight: 900;
    text-shadow: 0 15px 35px rgba(0,0,0,.4);
  }

  .school-map-hero p {
    max-width: 820px;
    margin: 14px auto 0;
    font-size: 19px;
    line-height: 1.7;
  }

  .location-section {
    padding: 90px 0;
    background: #f5f7fb;
  }

  .location-wrapper {
    width: 90%;
    max-width: 1400px;
    margin: auto;
    display: grid;
    grid-template-columns: .85fr 1.15fr;
    gap: 38px;
    align-items: stretch;
  }

  .location-info,
  .map-panel {
    border-radius: 32px;
    overflow: hidden;
    box-shadow: 0 24px 65px rgba(0,0,0,.14);
  }

  .location-info {
    background: linear-gradient(135deg, #001f3f, #004481);
    color: white;
    padding: 48px;
  }

  .location-info h2 {
    color: white;
    font-size: 40px;
    line-height: 1.2;
    margin-bottom: 25px;
  }

  .address-card {
    display: flex;
    gap: 18px;
    background: rgba(255,255,255,.11);
    padding: 22px;
    border-radius: 22px;
    margin-bottom: 26px;
    border: 1px solid rgba(255,255,255,.15);
  }

  .address-card i {
    color: #ffc300;
    font-size: 32px;
    margin-top: 4px;
  }

  .address-card h3 {
    color: #ffc300;
    margin-bottom: 8px;
    font-size: 22px;
  }

  .address-card p {
    line-height: 1.8;
    color: rgba(255,255,255,.92);
  }

  .route-info {
    display: grid;
    gap: 16px;
    margin-bottom: 28px;
  }

  .route-info div {
    background: rgba(255,255,255,.10);
    padding: 18px;
    border-radius: 18px;
    border-left: 4px solid #ffc300;
  }

  .route-info i {
    color: #ffc300;
    font-size: 24px;
    margin-bottom: 9px;
  }

  .route-info h4 {
    color: white;
    font-size: 19px;
    margin-bottom: 6px;
  }

  .route-info p {
    color: rgba(255,255,255,.88);
    line-height: 1.6;
  }

  .direction-btn {
    display: inline-block;
    background: #ffc300;
    color: #001f3f;
    padding: 16px 28px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 900;
    box-shadow: 0 14px 30px rgba(255,195,0,.28);
    transition: .35s;
  }

  .direction-btn:hover {
    background: white;
    transform: translateY(-5px);
  }

  .map-panel {
    background: white;
    display: flex;
    flex-direction: column;
  }

  .map-header {
    background: white;
    padding: 22px 28px;
    border-bottom: 1px solid #eef2f7;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .map-header h3 {
    color: #001f3f;
    font-size: 24px;
  }

  .map-header i {
    color: #ffc300;
  }

  .map-header span {
    background: #ffc300;
    color: #001f3f;
    padding: 8px 15px;
    border-radius: 30px;
    font-weight: 800;
    font-size: 13px;
  }

  .map-panel iframe {
    width: 100%;
    height: 100%;
    min-height: 620px;
    border: none;
  }

  .campus-guide-section {
    padding: 85px 0;
    background: white;
  }

  .guide-heading {
    text-align: center;
    margin-bottom: 55px;
  }

  .guide-heading h2 {
    color: #001f3f;
    font-size: 46px;
    margin-bottom: 14px;
  }

  .guide-heading p {
    color: #555;
    font-size: 18px;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .guide-card {
    background: #f5f7fb;
    padding: 35px;
    border-radius: 26px;
    text-align: center;
    box-shadow: 0 16px 40px rgba(0,0,0,.10);
    border-top: 5px solid #ffc300;
    transition: .35s;
  }

  .guide-card:hover {
    transform: translateY(-10px);
    background: #001f3f;
  }

  .guide-card i {
    color: #ffc300;
    font-size: 44px;
    margin-bottom: 18px;
  }

  .guide-card h3 {
    color: #001f3f;
    font-size: 24px;
    margin-bottom: 12px;
  }

  .guide-card p {
    color: #555;
    line-height: 1.7;
  }

  .guide-card:hover h3,
  .guide-card:hover p {
    color: white;
  }

  @media(max-width: 900px) {
    .location-wrapper,
    .guide-grid {
      grid-template-columns: 1fr;
    }

    .school-map-hero h1 {
      font-size: 42px;
    }

    .location-info h2,
    .guide-heading h2 {
      font-size: 34px;
    }

    .location-info {
      padding: 32px;
    }

    .map-header {
      display: block;
    }

    .map-header span {
      display: inline-block;
      margin-top: 10px;
    }

    .map-panel iframe {
      min-height: 420px;
    }
  }
</style>

<%- include('../partials/footer') %>