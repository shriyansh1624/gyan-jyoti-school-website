<%- include('../partials/header') %>

<section class="reg-hero">
  <div class="reg-container">
    <span class="hero-badge">Online Admission</span>
    <h1>Registration Form</h1>
    <p>
      Fill the admission registration form carefully. Our admission team will review
      your application and contact you soon.
    </p>

    <div class="hero-actions">
      <a href="/admission/enquiry">
        <i class="fas fa-question-circle"></i> Admission Enquiry
      </a>
      <a href="tel:+919876543210">
        <i class="fas fa-phone"></i> Call School
      </a>
    </div>
  </div>
</section>

<section class="registration-section">
  <div class="reg-container">

    <div class="section-heading">
      <span class="section-tag">Student Admission</span>
      <h2>Online Admission Registration</h2>
      <p>
        Please enter correct student, parent and contact details. Only valid details
        will be accepted by the system.
      </p>
    </div>

    <div class="registration-layout">

      <div class="reg-info-card">
        <div class="logo-box">
          <img src="/images/logo.png" alt="Gyan Jyoti Logo">
        </div>

        <h2>Gyan Jyoti School</h2>
        <p>
          Registration is the first step towards admission. Submit correct details
          and our team will contact you for the next process.
        </p>

        <div class="process-box">
          <div><span>01</span> Fill Registration Form</div>
          <div><span>02</span> Upload Required Document</div>
          <div><span>03</span> School Team Verification</div>
          <div><span>04</span> Admission Confirmation</div>
        </div>

        <div class="help-box">
          <i class="fas fa-shield-alt"></i>
          <p>Your details are protected and used only for admission purposes.</p>
        </div>
      </div>

      <div class="registration-card">

        <% if (typeof query !== 'undefined' && query.success) { %>
          <div class="success-msg">
            <i class="fas fa-check-circle"></i>
            Registration submitted successfully. Our team will contact you soon.
          </div>
        <% } %>

        <% if (typeof query !== 'undefined' && query.error) { %>
          <div class="error-msg">
            <i class="fas fa-exclamation-circle"></i>
            Something went wrong. Please fill all details correctly and try again.
          </div>
        <% } %>

        <form action="/admission/registration" method="POST" enctype="multipart/form-data" class="registration-form" novalidate>

          <div class="form-section-title">
            <i class="fas fa-user-graduate"></i>
            <h3>Student Details</h3>
          </div>

          <div class="form-grid">

            <div class="form-group">
              <label>Student Name <span>*</span></label>
              <input
                type="text"
                name="studentName"
                placeholder="Enter student name"
                pattern="[A-Za-z\s.]{3,70}"
                maxlength="70"
                title="Only letters allowed, minimum 3 characters"
                required
              >
            </div>

            <div class="form-group">
              <label>Class Applying For <span>*</span></label>
              <input
                type="text"
                name="class"
                placeholder="Example: Class 6"
                maxlength="30"
                required
              >
            </div>

          </div>

          <div class="form-section-title">
            <i class="fas fa-user-friends"></i>
            <h3>Parent / Guardian Details</h3>
          </div>

          <div class="form-grid">

            <div class="form-group">
              <label>Parent / Guardian Name <span>*</span></label>
              <input
                type="text"
                name="parentName"
                placeholder="Enter parent / guardian name"
                pattern="[A-Za-z\s.]{3,70}"
                maxlength="70"
                title="Only letters allowed, minimum 3 characters"
                required
              >
            </div>

            <div class="form-group">
              <label>Mobile Number <span>*</span></label>
              <input
                type="text"
                name="phone"
                placeholder="10 digit mobile number"
                pattern="[0-9]{10}"
                maxlength="10"
                inputmode="numeric"
                title="Enter exactly 10 digits"
                required
              >
            </div>

          </div>

          <div class="form-grid">

            <div class="form-group">
              <label>Email Address</label>
              <input
                type="email"
                name="email"
                placeholder="Enter email address"
                maxlength="80"
              >
            </div>

            <div class="form-group">
              <label>Upload Document</label>
              <input
                type="file"
                name="document"
                accept=".pdf,.jpg,.jpeg,.png"
              >
              <small class="file-note">
                Allowed: PDF, JPG, JPEG, PNG only. Max size: 2MB.
              </small>
            </div>

          </div>

          <div class="form-section-title">
            <i class="fas fa-map-marker-alt"></i>
            <h3>Address Details</h3>
          </div>

          <div class="form-group">
            <label>Full Address <span>*</span></label>
            <textarea
              name="address"
              placeholder="Enter full address"
              minlength="5"
              maxlength="500"
              required
            ></textarea>
          </div>

          <button type="submit" class="submit-btn">
            <i class="fas fa-paper-plane"></i> Submit Registration
          </button>

        </form>

      </div>

    </div>

  </div>
</section>

<section class="registration-support">
  <div class="reg-container">

    <div class="support-grid">
      <div class="support-card">
        <i class="fas fa-file-alt"></i>
        <h3>Document Upload</h3>
        <p>Upload admission related document in PDF, JPG or PNG format.</p>
      </div>

      <div class="support-card">
        <i class="fas fa-phone-volume"></i>
        <h3>Admission Support</h3>
        <p>Our school team will call you after successful registration.</p>
      </div>

      <div class="support-card">
        <i class="fas fa-school"></i>
        <h3>School Visit</h3>
        <p>Parents can visit school office for admission confirmation.</p>
      </div>
    </div>

  </div>
</section>

<style>
  .reg-container {
    width: 86%;
    max-width: 1200px;
    margin: auto;
  }

  .reg-hero {
    min-height: 500px;
    background:
      linear-gradient(rgba(0,31,63,.84), rgba(0,31,63,.84)),
      url('/images/school-bg.jpg');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .reg-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,195,0,.35) 2px, transparent 2px),
      radial-gradient(circle, rgba(255,255,255,.14) 1px, transparent 1px);
    background-size: 120px 120px, 75px 75px;
    animation: regDots 22s linear infinite;
  }

  @keyframes regDots {
    from { transform: translateY(0); }
    to { transform: translateY(-120px); }
  }

  .reg-hero .reg-container {
    position: relative;
    z-index: 2;
  }

  .hero-badge,
  .section-tag {
    display: inline-block;
    background: #ffc300;
    color: #001f3f;
    padding: 9px 22px;
    border-radius: 40px;
    font-weight: 900;
    margin-bottom: 15px;
  }

  .reg-hero h1 {
    color: white;
    font-size: 64px;
    font-weight: 900;
    margin-bottom: 14px;
    text-shadow: 0 15px 35px rgba(0,0,0,.4);
  }

  .reg-hero p {
    max-width: 850px;
    margin: auto;
    color: white;
    font-size: 19px;
    line-height: 1.7;
  }

  .hero-actions {
    margin-top: 28px;
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  .hero-actions a {
    background: #ffc300;
    color: #001f3f;
    padding: 14px 24px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 900;
    transition: .35s;
    box-shadow: 0 14px 30px rgba(255,195,0,.28);
  }

  .hero-actions a:hover {
    background: white;
    transform: translateY(-5px);
  }

  .registration-section {
    padding: 85px 0;
    background: #f5f7fb;
  }

  .section-heading {
    text-align: center;
    margin-bottom: 55px;
  }

  .section-heading h2 {
    color: #001f3f;
    font-size: 46px;
    margin-bottom: 14px;
  }

  .section-heading p {
    max-width: 850px;
    margin: auto;
    color: #555;
    font-size: 18px;
    line-height: 1.7;
  }

  .registration-layout {
    display: grid;
    grid-template-columns: .9fr 1.1fr;
    gap: 40px;
    align-items: start;
  }

  .reg-info-card,
  .registration-card {
    border-radius: 30px;
    padding: 42px;
    box-shadow: 0 22px 55px rgba(0,0,0,.13);
    position: relative;
    overflow: hidden;
  }

  .reg-info-card {
    background: linear-gradient(135deg, #001f3f, #004481);
    color: white;
    position: sticky;
    top: 120px;
  }

  .registration-card {
    background: white;
  }

  .reg-info-card::after,
  .registration-card::after {
    content: "";
    position: absolute;
    width: 260px;
    height: 260px;
    background: rgba(255,195,0,.12);
    border-radius: 50%;
    top: -130px;
    right: -130px;
  }

  .reg-info-card > *,
  .registration-card > * {
    position: relative;
    z-index: 2;
  }

  .logo-box {
    width: 115px;
    height: 115px;
    background: white;
    border-radius: 50%;
    padding: 8px;
    border: 5px solid #ffc300;
    margin-bottom: 24px;
  }

  .logo-box img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .reg-info-card h2 {
    color: #ffc300;
    font-size: 32px;
    margin-bottom: 12px;
  }

  .reg-info-card > p {
    color: rgba(255,255,255,.9);
    font-size: 17px;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .process-box {
    display: grid;
    gap: 14px;
    margin-bottom: 26px;
  }

  .process-box div {
    background: rgba(255,255,255,.10);
    padding: 15px 16px;
    border-radius: 16px;
    border-left: 4px solid #ffc300;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .process-box span {
    width: 34px;
    height: 34px;
    background: #ffc300;
    color: #001f3f;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
  }

  .help-box {
    background: rgba(255,255,255,.12);
    padding: 18px;
    border-radius: 18px;
    display: flex;
    gap: 15px;
    align-items: flex-start;
  }

  .help-box i {
    color: #ffc300;
    font-size: 26px;
  }

  .help-box p {
    color: rgba(255,255,255,.9);
    line-height: 1.6;
  }

  .form-section-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 8px 0 22px;
    padding-bottom: 12px;
    border-bottom: 1px solid #e5e7eb;
  }

  .form-section-title i {
    width: 42px;
    height: 42px;
    background: #001f3f;
    color: #ffc300;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .form-section-title h3 {
    color: #001f3f;
    font-size: 22px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .form-group {
    margin-bottom: 18px;
  }

  .form-group label {
    display: block;
    color: #001f3f;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .form-group span {
    color: #dc2626;
  }

  .registration-form input,
  .registration-form textarea {
    width: 100%;
    padding: 15px 18px;
    border: 1px solid #d1d5db;
    border-radius: 14px;
    font-size: 15px;
    outline: none;
    transition: .3s;
    background: white;
  }

  .registration-form textarea {
    height: 140px;
    resize: none;
  }

  .registration-form input:focus,
  .registration-form textarea:focus {
    border-color: #ffc300;
    box-shadow: 0 0 0 4px rgba(255,195,0,.22);
  }

  .file-note {
    display: block;
    margin-top: 7px;
    color: #666;
    font-size: 13px;
    line-height: 1.4;
  }

  .submit-btn {
    border: none;
    background: linear-gradient(135deg, #ffc300, #ffdd55);
    color: #001f3f;
    padding: 16px 32px;
    border-radius: 50px;
    font-weight: 900;
    cursor: pointer;
    font-size: 15px;
    box-shadow: 0 12px 28px rgba(255,195,0,.35);
    transition: .35s;
  }

  .submit-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 35px rgba(255,195,0,.45);
  }

  .submit-btn:disabled {
    opacity: .7;
    cursor: not-allowed;
  }

  .success-msg,
  .error-msg {
    padding: 14px 16px;
    border-radius: 14px;
    margin-bottom: 20px;
    font-weight: 800;
    line-height: 1.5;
  }

  .success-msg {
    background: #d1e7dd;
    color: #0f5132;
  }

  .error-msg {
    background: #f8d7da;
    color: #842029;
  }

  .registration-support {
    padding: 80px 0;
    background: white;
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .support-card {
    background: #f5f7fb;
    padding: 35px;
    text-align: center;
    border-radius: 26px;
    box-shadow: 0 16px 40px rgba(0,0,0,.10);
    border-top: 5px solid #ffc300;
    transition: .35s;
  }

  .support-card:hover {
    background: #001f3f;
    transform: translateY(-10px);
  }

  .support-card i {
    color: #ffc300;
    font-size: 42px;
    margin-bottom: 18px;
  }

  .support-card h3 {
    color: #001f3f;
    font-size: 24px;
    margin-bottom: 10px;
  }

  .support-card p {
    color: #555;
    line-height: 1.7;
  }

  .support-card:hover h3,
  .support-card:hover p {
    color: white;
  }

  @media(max-width: 900px) {
    .registration-layout,
    .form-grid,
    .support-grid {
      grid-template-columns: 1fr;
    }

    .reg-info-card {
      position: relative;
      top: 0;
    }

    .reg-hero h1 {
      font-size: 42px;
    }

    .section-heading h2 {
      font-size: 34px;
    }

    .reg-info-card,
    .registration-card {
      padding: 30px;
    }
  }
</style>

<script>
  const registrationForm = document.querySelector('.registration-form');

  if (registrationForm) {
    registrationForm.addEventListener('submit', function(e) {
      const studentName = this.studentName.value.trim();
      const parentName = this.parentName.value.trim();
      const phone = this.phone.value.trim();
      const address = this.address.value.trim();
      const file = this.document.files[0];

      const nameRegex = /^[A-Za-z\s.]{3,70}$/;

      if (!nameRegex.test(studentName)) {
        alert('Student name should contain only letters and minimum 3 characters.');
        e.preventDefault();
        return;
      }

      if (!nameRegex.test(parentName)) {
        alert('Parent / Guardian name should contain only letters and minimum 3 characters.');
        e.preventDefault();
        return;
      }

      if (!/^[0-9]{10}$/.test(phone)) {
        alert('Mobile number must be exactly 10 digits.');
        e.preventDefault();
        return;
      }

      if (address.length < 5) {
        alert('Address must be at least 5 characters.');
        e.preventDefault();
        return;
      }

      if (file) {
        const allowedTypes = ['application/pdf', 'image/jpeg', 'image/png'];

        if (!allowedTypes.includes(file.type)) {
          alert('Only PDF, JPG, JPEG and PNG files are allowed.');
          e.preventDefault();
          return;
        }

        if (file.size > 2 * 1024 * 1024) {
          alert('File size must be below 2MB.');
          e.preventDefault();
          return;
        }
      }

      const btn = this.querySelector('.submit-btn');
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';
      btn.disabled = true;
    });
  }
</script>

<%- include('../partials/footer') %>