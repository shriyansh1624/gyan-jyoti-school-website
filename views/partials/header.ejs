<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= typeof title !== 'undefined' ? title : 'Gyan Jyoti School' %></title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/responsive.css">
</head>

<body>

<!-- TOP HEADER -->
<div class="top-header">
  <div class="container top-header-container">

    <div class="top-header-left">
      <span>
        <i class="fas fa-envelope"></i>
        <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.email ? schoolInfo.email : 'info@gyanjyoti.com' %>
      </span>

      <span>
        <i class="fas fa-phone"></i>
        <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.phone ? schoolInfo.phone : '+91 98765-43210' %>
      </span>
    </div>

    <div class="top-header-right">
      <% if (typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.socialLinks) { %>

        <% if (schoolInfo.socialLinks.facebook) { %>
          <a href="<%= schoolInfo.socialLinks.facebook %>" target="_blank" aria-label="Facebook">
            <i class="fab fa-facebook"></i>
          </a>
        <% } %>

        <% if (schoolInfo.socialLinks.instagram) { %>
          <a href="<%= schoolInfo.socialLinks.instagram %>" target="_blank" aria-label="Instagram">
            <i class="fab fa-instagram"></i>
          </a>
        <% } %>

        <% if (schoolInfo.socialLinks.youtube) { %>
          <a href="<%= schoolInfo.socialLinks.youtube %>" target="_blank" aria-label="YouTube">
            <i class="fab fa-youtube"></i>
          </a>
        <% } %>

        <% if (schoolInfo.socialLinks.whatsapp) { %>
          <a href="<%= schoolInfo.socialLinks.whatsapp %>" target="_blank" aria-label="WhatsApp">
            <i class="fab fa-whatsapp"></i>
          </a>
        <% } %>

      <% } else { %>
        <a href="#" aria-label="Facebook"><i class="fab fa-facebook"></i></a>
        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      <% } %>
    </div>

  </div>
</div>

<!-- MAIN HEADER -->
<header class="main-header">
  <div class="container main-header-container">

    <a href="/" class="logo-section">
      <img
        src="<%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.logo ? schoolInfo.logo : '/images/logo.png' %>"
        alt="Gyan Jyoti School Logo"
        class="school-logo"
      >

      <div class="school-info">
        <h1>
          <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.schoolName ? schoolInfo.schoolName : 'Gyan Jyoti' %>
        </h1>

        <p>
          <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.tagline ? schoolInfo.tagline : 'International School' %>
        </p>

        <small>
          <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.affiliation ? schoolInfo.affiliation : 'CBSE Affiliation No. 1030842' %>
        </small>
      </div>
    </a>

    <button class="hamburger" type="button" id="hamburgerBtn" aria-label="Open navigation menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="navbar" id="mainNavbar">
      <ul class="nav-menu" id="navMenu">

        <li>
          <a href="/" class="<%= typeof active !== 'undefined' && active === 'home' ? 'active' : '' %>">HOME</a>
        </li>

        <li class="dropdown">
          <button type="button" class="nav-dropdown-btn <%= typeof active !== 'undefined' && active === 'about' ? 'active' : '' %>">
            ABOUT US <i class="fas fa-chevron-down"></i>
          </button>
          <ul class="dropdown-menu">
            <li><a href="/about">ABOUT SCHOOL</a></li>
            <li><a href="/about/vision">VISION & MISSION</a></li>
            <li><a href="/about/founder">FOUNDER'S MESSAGE</a></li>
            <li><a href="/about/principal">PRINCIPAL'S MESSAGE</a></li>
            <li><a href="/about/advantages">MIS ADVANTAGES</a></li>
            <li><a href="/about/accolades">DEVELOPER AND MEMBER</a></li>
          </ul>
        </li>

        <li class="dropdown">
          <button type="button" class="nav-dropdown-btn <%= typeof active !== 'undefined' && active === 'academics' ? 'active' : '' %>">
            ACADEMICS <i class="fas fa-chevron-down"></i>
          </button>
          <ul class="dropdown-menu">
            <li><a href="/academics">ACADEMICS OVERVIEW</a></li>
            <li><a href="/academics/10th-toppers">10TH BOARD TOPPERS</a></li>
            <li><a href="/academics/12th-toppers">12TH BOARD TOPPERS</a></li>
            <li><a href="/academics/school-toppers">SCHOOL TOPPERS</a></li>
            <li><a href="/academics/sports-records">SPORTS ACADEMIC RECORDS</a></li>
          </ul>
        </li>

        <li class="dropdown">
          <button type="button" class="nav-dropdown-btn <%= typeof active !== 'undefined' && active === 'events' ? 'active' : '' %>">
            EVENTS <i class="fas fa-chevron-down"></i>
          </button>
          <ul class="dropdown-menu">
            <li><a href="/events/fun-fiesta">FUN & FIESTA</a></li>
            <li><a href="/events/sports">SPORTS</a></li>
            <li><a href="/events/republic-day">REPUBLIC DAY</a></li>
            <li><a href="/events/independence-day">INDEPENDENCE DAY</a></li>
          </ul>
        </li>

        <li class="dropdown">
          <button type="button" class="nav-dropdown-btn <%= typeof active !== 'undefined' && active === 'admission' ? 'active' : '' %>">
            ADMISSION <i class="fas fa-chevron-down"></i>
          </button>
          <ul class="dropdown-menu">
            <li><a href="/admission/process">ADMISSION PROCESS</a></li>
            <li><a href="/admission/enquiry">ENQUIRY FORM</a></li>
            <li><a href="/admission/registration">REGISTRATION FORM</a></li>
            <li><a href="/admission/guidelines">GUIDELINES & POLICIES</a></li>
            <li><a href="/admission/map">MAP OF SCHOOL</a></li>
            <li><a href="/fees">FEES STRUCTURE</a></li>
          </ul>
        </li>

        <li><a href="/faculty" class="<%= typeof active !== 'undefined' && active === 'faculty' ? 'active' : '' %>">FACULTY</a></li>
        <li><a href="/contact" class="<%= typeof active !== 'undefined' && active === 'contact' ? 'active' : '' %>">CONTACT</a></li>

      </ul>
    </nav>

  </div>
</header>

<style>
  * { box-sizing: border-box; }
  html, body { width: 100%; overflow-x: hidden; }
  body { margin: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; background: #fff; }
  .container { width: 86%; max-width: 1200px; margin: 0 auto; }

  .top-header { background: #001f3f; color: #fff; font-size: 13px; padding: 10px 0; }
  .top-header-container { display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .top-header-left { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; }
  .top-header-left span { display: inline-flex; align-items: center; gap: 8px; }
  .top-header-left i, .top-header-right i { color: #ffc300; }
  .top-header-right { display: flex; align-items: center; gap: 16px; }
  .top-header-right a { color: #fff; text-decoration: none; transition: .3s; }
  .top-header-right a:hover { color: #ffc300; }

  .main-header { position: sticky; top: 0; z-index: 99999; background: #fff; box-shadow: 0 8px 28px rgba(0,0,0,.10); }
  .main-header-container { display: flex; align-items: center; justify-content: space-between; gap: 22px; min-height: 95px; position: relative; }
  .logo-section { display: flex; align-items: center; gap: 14px; min-width: 290px; text-decoration: none; }
  .school-logo { width: 78px; height: 78px; object-fit: contain; background: #fff; border-radius: 50%; padding: 3px; filter: drop-shadow(0 8px 14px rgba(0,0,0,.14)); flex-shrink: 0; }
  .school-info h1 { margin: 0; color: #8b0000; font-size: 25px; font-weight: 900; line-height: 1.1; }
  .school-info p { margin: 4px 0 0; color: #333; font-size: 13px; font-weight: 700; }
  .school-info small { display: block; margin-top: 2px; color: #666; font-size: 11px; }

  .navbar { flex: 1; display: flex; justify-content: flex-end; }
  .nav-menu { display: flex; align-items: center; justify-content: flex-end; list-style: none; gap: 0; margin: 0; padding: 0; }
  .nav-menu > li { position: relative; list-style: none; }
  .nav-menu > li > a, .nav-dropdown-btn { display: flex; align-items: center; gap: 6px; padding: 15px 13px; color: #222; background: transparent; border: none; text-decoration: none; font-size: 12px; font-weight: 900; text-transform: uppercase; cursor: pointer; white-space: nowrap; transition: .3s; font-family: inherit; }
  .nav-menu > li > a:hover, .nav-menu > li > a.active, .nav-dropdown-btn:hover, .nav-dropdown-btn.active, .dropdown:hover > .nav-dropdown-btn { background: #ffc300; color: #001f3f; text-decoration: none; }
  .dropdown-menu { position: absolute; top: 100%; left: 0; min-width: 260px; background: #001f3f; list-style: none; padding: 0; margin: 0; display: none; border-top: 4px solid #ffc300; border-radius: 0 0 12px 12px; overflow: hidden; box-shadow: 0 18px 42px rgba(0,0,0,.32); z-index: 999999; }
  .dropdown:hover > .dropdown-menu { display: block; }
  .dropdown-menu li a { display: block; padding: 14px 20px; color: #fff; background: #001f3f; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,.12); font-size: 12px; font-weight: 800; text-transform: uppercase; white-space: nowrap; transition: .3s; }
  .dropdown-menu li:last-child a { border-bottom: none; }
  .dropdown-menu li a:hover { background: #ffc300; color: #001f3f; padding-left: 30px; }

  .hamburger { display: none; width: 46px; height: 42px; border: none; background: #001f3f; border-radius: 10px; align-items: center; justify-content: center; flex-direction: column; gap: 5px; cursor: pointer; flex-shrink: 0; }
  .hamburger span { width: 24px; height: 3px; background: #ffc300; border-radius: 10px; transition: .3s; }
  .hamburger.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  @media (max-width: 1100px) {
    .main-header-container { width: 94%; }
    .logo-section { min-width: 250px; }
    .nav-menu > li > a, .nav-dropdown-btn { padding: 14px 9px; font-size: 11px; }
  }

  @media (max-width: 900px) {
    .container { width: 92%; }
    .top-header-container { flex-direction: column; text-align: center; gap: 8px; }
    .top-header-left { justify-content: center; gap: 10px; font-size: 12px; }
    .main-header-container { min-height: 82px; width: 94%; }
    .logo-section { min-width: auto; flex: 1; gap: 10px; }
    .school-logo { width: 62px; height: 62px; }
    .school-info h1 { font-size: 20px; }
    .school-info p { font-size: 11px; }
    .school-info small { font-size: 9px; }
    .hamburger { display: flex; }
    .navbar { position: absolute; top: 100%; left: 0; right: 0; display: none; width: 100%; background: #fff; border-top: 3px solid #ffc300; box-shadow: 0 18px 35px rgba(0,0,0,.15); max-height: calc(100vh - 100px); overflow-y: auto; }
    .navbar.open { display: block; }
    .nav-menu { display: block; width: 100%; padding: 8px 0; }
    .nav-menu > li { width: 100%; border-bottom: 1px solid #eef2f7; }
    .nav-menu > li > a, .nav-dropdown-btn { width: 100%; justify-content: space-between; padding: 15px 18px; font-size: 13px; text-align: left; }
    .dropdown-menu { position: static; display: none; width: 100%; min-width: 100%; border-top: none; border-radius: 0; box-shadow: none; }
    .dropdown.open > .dropdown-menu { display: block; }
    .dropdown:hover > .dropdown-menu { display: none; }
    .dropdown.open:hover > .dropdown-menu { display: block; }
    .dropdown-menu li a { padding: 13px 28px; font-size: 12px; white-space: normal; }
  }

  @media (max-width: 480px) {
    .top-header { display: none; }
    .main-header-container { min-height: 76px; }
    .school-logo { width: 54px; height: 54px; }
    .school-info h1 { font-size: 18px; }
    .school-info p { font-size: 10px; }
    .school-info small { display: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const mainNavbar = document.getElementById('mainNavbar');
    const dropdownButtons = document.querySelectorAll('.nav-dropdown-btn');

    if (hamburgerBtn && mainNavbar) {
      hamburgerBtn.addEventListener('click', function () {
        hamburgerBtn.classList.toggle('active');
        mainNavbar.classList.toggle('open');
        document.body.classList.toggle('menu-open');
      });
    }

    dropdownButtons.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        if (window.innerWidth <= 900) {
          e.preventDefault();
          const parent = btn.closest('.dropdown');
          document.querySelectorAll('.dropdown.open').forEach(function (item) {
            if (item !== parent) item.classList.remove('open');
          });
          parent.classList.toggle('open');
        }
      });
    });

    document.addEventListener('click', function (e) {
      if (window.innerWidth <= 900) {
        const clickedInsideHeader = e.target.closest('.main-header');
        if (!clickedInsideHeader && mainNavbar && hamburgerBtn) {
          mainNavbar.classList.remove('open');
          document.body.classList.remove('menu-open');
          hamburgerBtn.classList.remove('active');
          document.querySelectorAll('.dropdown.open').forEach(function (item) {
            item.classList.remove('open');
          });
        }
      }
    });
  });
</script>
