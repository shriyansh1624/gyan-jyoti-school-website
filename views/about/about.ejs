<%- include('../partials/header') %>

<section class="about-page-hero">
  <div class="about-page-overlay">
    <div class="about-container">
      <span class="about-mini">Since 1973</span>
      <h1>About Gyan Jyoti School</h1>
      <p><a href="/" style="color:#ffc300">Home</a> / About Us</p>
    </div>
  </div>
</section>

<section class="about-history">
  <div class="about-container">
    <div class="about-history-card">

      <div class="about-history-text">
        <span class="section-tag">Our Foundation</span>

        <h2>
          <%= about && about.title ? about.title : 'Established by Nainpur Vikas Samiti' %>
        </h2>

        <p>
          <%= about && about.content ? about.content : 'Gyan Jyoti School was established in 1973 by Nainpur Vikas Samiti with a vision to provide quality education at every level. The school is committed to academic excellence, discipline, moral values and overall personality development of students.' %>
        </p>

        <p>
          The institution continues to provide a positive learning environment where
          students grow with confidence, creativity and strong educational values.
        </p>
      </div>

      <div class="about-history-image">
        <img src="<%= about && about.image ? about.image : '/images/school-bg.jpg' %>" alt="Gyan Jyoti School">
      </div>

    </div>
  </div>
</section>

<section class="about-values">
  <div class="about-container">
    <div class="section-heading">
      <span class="section-tag">Why Gyan Jyoti</span>
      <h2>Education With Values & Excellence</h2>
      <p>
        We focus on quality education, discipline, confidence, creativity and holistic development.
      </p>
    </div>

    <div class="values-grid">
      <div class="value-card">
        <i class="fas fa-book-open"></i>
        <h3>Quality Education</h3>
        <p>Strong academic foundation with learning at every level.</p>
      </div>

      <div class="value-card">
        <i class="fas fa-user-graduate"></i>
        <h3>Student Development</h3>
        <p>Focus on confidence, discipline, creativity and personality development.</p>
      </div>

      <div class="value-card">
        <i class="fas fa-school"></i>
        <h3>Experienced Guidance</h3>
        <p>Dedicated guidance by Nainpur Vikas Samiti and school leadership.</p>
      </div>
    </div>
  </div>
</section>

<section class="nvs-members-section">
  <div class="about-container">

    <div class="section-heading">
      <span class="section-tag">Nainpur Vikas Samiti</span>
      <h2>Committee Members</h2>
      <p>
        The school is supported by dedicated Nainpur Vikas Samiti members who guide
        the institution with vision, experience and commitment.
      </p>
    </div>

    <div class="members-grid">

