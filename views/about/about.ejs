<style>
  .about-container {
    width: 86%;
    max-width: 1200px;
    margin: auto;
  }

  .about-page-hero {
    height: 420px;
    background:
      linear-gradient(rgba(0,31,63,.75), rgba(0,31,63,.75)),
      url('/images/school-bg.jpg');
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
  }

  .about-page-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,195,0,.30) 2px, transparent 2px),
      radial-gradient(circle, rgba(255,255,255,.14) 1px, transparent 1px);
    background-size: 120px 120px, 75px 75px;
    animation: aboutDots 22s linear infinite;
  }

  @keyframes aboutDots {
    from { transform: translateY(0); }
    to { transform: translateY(-120px); }
  }

  .about-page-overlay {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .about-mini,
  .section-tag {
    display: inline-block;
    background: #ffc300;
    color: #001f3f;
    padding: 9px 20px;
    border-radius: 40px;
    font-weight: 900;
    margin-bottom: 15px;
  }

  .about-page-hero h1 {
    color: white;
    font-size: 62px;
    font-weight: 900;
    margin-bottom: 12px;
    text-shadow: 0 15px 35px rgba(0,0,0,.35);
  }

  .about-page-hero p,
  .about-page-hero a {
    color: white;
    font-size: 18px;
  }

  .about-history {
    padding: 80px 0;
    background: #f5f7fb;
  }

  .about-history-card {
    background: white;
    border-radius: 28px;
    padding: 40px;
    display: grid;
    grid-template-columns: 1.15fr .85fr;
    gap: 40px;
    align-items: center;
    box-shadow: 0 18px 45px rgba(0,0,0,.12);
  }

  .about-history-text h2 {
    font-size: 42px;
    color: #001f3f;
    margin-bottom: 18px;
    line-height: 1.2;
  }

  .about-history-text p {
    font-size: 18px;
    color: #444;
    line-height: 1.8;
    margin-bottom: 15px;
  }

  .about-history-image {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0,0,0,.18);
  }

  .about-history-image img {
    width: 100%;
    height: 360px;
    object-fit: cover;
    transition: .6s;
  }

  .about-history-image:hover img {
    transform: scale(1.08);
  }

  .about-values {
    padding: 80px 0;
    background: white;
  }

  .section-heading {
    text-align: center;
    margin-bottom: 50px;
  }

  .section-heading h2 {
    font-size: 46px;
    color: #001f3f;
    margin-bottom: 15px;
  }

  .section-heading p {
    max-width: 850px;
    margin: auto;
    font-size: 18px;
    color: #555;
    line-height: 1.7;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .value-card {
    background: #f5f7fb;
    padding: 35px;
    border-radius: 22px;
    text-align: center;
    box-shadow: 0 12px 30px rgba(0,0,0,.10);
    border-top: 5px solid #ffc300;
    transition: .35s;
  }

  .value-card:hover {
    transform: translateY(-10px);
    background: #001f3f;
  }

  .value-card:hover h3,
  .value-card:hover p {
    color: white;
  }

  .value-card i {
    font-size: 42px;
    color: #ffc300;
    margin-bottom: 18px;
  }

  .value-card h3 {
    color: #001f3f;
    margin-bottom: 12px;
    font-size: 24px;
  }

  .value-card p {
    color: #555;
    line-height: 1.7;
  }

  .nvs-members-section {
    padding: 80px 0;
    background: #f5f7fb;
  }

  .members-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 35px;
    margin-top: 50px;
  }

  .member-card {
    position: relative;
    overflow: hidden;
    background: #fff;
    border-radius: 25px;
    padding: 35px 25px;
    text-align: center;
    box-shadow: 0 15px 40px rgba(0,0,0,.12);
    transition: all .5s ease;
    border: 1px solid rgba(255,195,0,.15);
    animation: memberFade .8s ease forwards;
    opacity: 0;
  }

  .member-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 5px;
    background: linear-gradient(
      90deg,
      transparent,
      #ffc300,
      #fff,
      #ffc300,
      transparent
    );
    transition: .7s;
  }

  .member-card:hover::before {
    left: 100%;
  }

  .member-card::after {
    content: "";
    position: absolute;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    background: rgba(255,195,0,.08);
    top: -120px;
    right: -120px;
    transition: .5s;
  }

  .member-card:hover::after {
    transform: scale(1.4);
  }

  .member-card:hover {
    transform: translateY(-15px) scale(1.03);
    box-shadow: 0 25px 60px rgba(0,0,0,.25);
  }

  .member-photo {
    width: 140px;
    height: 140px;
    margin: auto;
    border-radius: 50%;
    overflow: hidden;
    border: 5px solid #ffc300;
    box-shadow: 0 10px 30px rgba(0,0,0,.2);
    transition: .6s;
    position: relative;
    z-index: 2;
  }

  .member-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: .7s;
  }

  .member-card:hover .member-photo {
    transform: rotate(5deg) scale(1.08);
  }

  .member-card:hover .member-photo img {
    transform: scale(1.15);
  }

  .member-card h3 {
    margin-top: 18px;
    color: #001f3f;
    font-size: 24px;
    font-weight: 800;
    position: relative;
    z-index: 2;
    transition: .4s;
  }

  .member-card:hover h3 {
    color: #b8860b;
  }

  .member-designation {
    display: inline-block;
    margin: 12px 0;
    background: linear-gradient(135deg, #ffc300, #ffdd55);
    color: #001f3f;
    padding: 8px 18px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 800;
    box-shadow: 0 5px 15px rgba(255,195,0,.4);
    position: relative;
    z-index: 2;
    transition: .4s;
  }

  .member-card:hover .member-designation {
    transform: scale(1.08);
  }

  .member-card p {
    color: #555;
    margin: 8px 0;
    font-size: 15px;
    line-height: 1.6;
    position: relative;
    z-index: 2;
  }

  .member-social {
    margin-top: 18px;
    position: relative;
    z-index: 2;
  }

  .member-social a {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #001f3f;
    color: white;
    border-radius: 50%;
    margin: 0 4px;
    transition: .4s;
    text-decoration: none;
  }

  .member-social a:hover {
    background: #ffc300;
    color: #001f3f;
    transform: translateY(-5px);
  }

  @keyframes memberFade {
    from {
      opacity: 0;
      transform: translateY(50px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(45px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media(max-width: 900px) {
    .about-history-card,
    .values-grid {
      grid-template-columns: 1fr;
    }

    .about-page-hero h1 {
      font-size: 42px;
    }

    .section-heading h2,
    .about-history-text h2 {
      font-size: 34px;
    }
  }
</style>

<%- include('../partials/footer') %>