<script>
  let slideIndex = 0;
  let slideTimer;

  function getSlides() {
    return document.querySelectorAll('.home-carousel-item');
  }

  function buildDots() {
    const dotsWrapper = document.getElementById('carouselDots');
    const slides = getSlides();

    if (!dotsWrapper || !slides.length) return;

    dotsWrapper.innerHTML = '';

    slides.forEach(function (_, index) {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'home-dot' + (index === 0 ? ' active' : '');
      dot.setAttribute('aria-label', 'Go to slide ' + (index + 1));
      dot.onclick = function () {
        goToSlide(index);
      };
      dotsWrapper.appendChild(dot);
    });
  }

  function updateDots() {
    const dots = document.querySelectorAll('.home-dot');

    dots.forEach(function (dot, index) {
      dot.classList.toggle('active', index === slideIndex);
    });
  }

  function showSlide(n) {
    const slides = getSlides();
    const carousel = document.getElementById('carouselInner');

    if (!slides.length || !carousel) return;

    if (n >= slides.length) slideIndex = 0;
    if (n < 0) slideIndex = slides.length - 1;

    carousel.style.transform = 'translateX(-' + (slideIndex * 100) + '%)';
    updateDots();
  }

  function changeSlide(n) {
    showSlide(slideIndex += n);
    resetTimer();
  }

  function goToSlide(index) {
    slideIndex = index;
    showSlide(slideIndex);
    resetTimer();
  }

  function resetTimer() {
    clearInterval(slideTimer);
    slideTimer = setInterval(function () {
      changeSlide(1);
    }, 5000);
  }

  document.addEventListener('DOMContentLoaded', function () {
    buildDots();
    showSlide(0);
    resetTimer();
  });
</script>

