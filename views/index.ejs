<%- include('partials/header') %>

<section class="home-hero-section">
  <div class="home-hero-wrapper">

    <div class="home-carousel">
      <div class="home-carousel-inner" id="carouselInner">

        <% if (typeof sliders !== 'undefined' && sliders && sliders.length > 0) { %>
          <% sliders.forEach((slider, index) => { %>
            <div
              class="home-carousel-item <%= index === 0 ? 'active' : '' %>"
              style="background-image:url('<%= slider.image %>');"
            >
              <div class="home-carousel-overlay"></div>

              <div class="home-carousel-content">
                <span class="hero-mini-text">Welcome To Gyan Jyoti</span>

                <h2><%= slider.title %></h2>

                <p><%= slider.subtitle %></p>

                <a href="<%= slider.buttonLink %>" class="home-primary-btn">
                  <%= slider.buttonText %>
                </a>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="home-carousel-item active" style="background-image:url('/images/school-bg.jpg');">
            <div class="home-carousel-overlay"></div>

            <div class="home-carousel-content">
              <span class="hero-mini-text">Welcome To Gyan Jyoti</span>

              <h2>Welcome to Gyan Jyoti</h2>

              <p>Excellence in Education, Character & Culture</p>

              <a href="/admission/process" class="home-primary-btn">
                Start Admission
              </a>
            </div>
          </div>
        <% } %>

      </div>

      <button class="home-carousel-btn prev" type="button" onclick="changeSlide(-1)" aria-label="Previous slide">
        <i class="fas fa-chevron-left"></i>
      </button>

      <button class="home-carousel-btn next" type="button" onclick="changeSlide(1)" aria-label="Next slide">
        <i class="fas fa-chevron-right"></i>
      </button>

      <div class="home-carousel-dots" id="carouselDots"></div>
    </div>

    <aside class="home-side-panel">
      <div class="home-panel-title">
        <i class="fas fa-school"></i>
        <span>Quick Links</span>
      </div>

      <ul>
        <li><a href="/about/vision"><i class="fas fa-bullseye"></i> Vision & Mission</a></li>
        <li><a href="/about/founder"><i class="fas fa-user-tie"></i> Founder's Message</a></li>
        <li><a href="/about/principal"><i class="fas fa-chalkboard-teacher"></i> Principal's Message</a></li>
        <li><a href="/about/advantages"><i class="fas fa-star"></i> MIS Advantages</a></li>
        <li><a href="/faculty"><i class="fas fa-users"></i> Staff Directory</a></li>
        <li><a href="/about/accolades"><i class="fas fa-code"></i> Developer and Member</a></li>
        <li><a href="/about/partners"><i class="fas fa-handshake"></i> Knowledge Partners</a></li>
        <li><a href="/fees"><i class="fas fa-file-invoice"></i> Fees Structure</a></li>
      </ul>
    </aside>

  </div>
</section>

<section class="home-welcome-section">
  <div class="container">

    <div class="home-section-heading">
      <span>Our Strength</span>
      <h2>Welcome to Gyan Jyoti</h2>
      <p>
        Excellence in Education, Character & Culture — shaping confident,
        responsible and future-ready students.
      </p>
    </div>

    <div class="welcome-grid">

      <div class="welcome-box">
        <div class="welcome-icon">
          <i class="fas fa-graduation-cap"></i>
        </div>

        <h3>Quality Education</h3>
        <p>
          We provide strong academic learning with modern teaching methods,
          discipline and regular assessment.
        </p>
      </div>

      <div class="welcome-box">
        <div class="welcome-icon">
          <i class="fas fa-users"></i>
        </div>

        <h3>Expert Faculty</h3>
        <p>
          Experienced and dedicated teachers guide students with personal attention
          and concept clarity.
        </p>
      </div>

      <div class="welcome-box">
        <div class="welcome-icon">
          <i class="fas fa-book"></i>
        </div>

        <h3>CBSE Curriculum</h3>
        <p>
          Comprehensive curriculum with focus on holistic development, academics
          and co-curricular activities.
        </p>
      </div>

      <div class="welcome-box">
        <div class="welcome-icon">
          <i class="fas fa-trophy"></i>
        </div>

        <h3>Achievements</h3>
        <p>
          Excellence in academics, sports and cultural activities with a proud
          track record of success.
        </p>
      </div>

    </div>

  </div>
</section>

<section class="home-stats-section">
  <div class="container">
    <div class="stats-grid">

      <div class="stat-card">
        <h3>50+</h3>
        <p>Years of Educational Service</p>
      </div>

      <div class="stat-card">
        <h3>100%</h3>
        <p>Focus on Student Growth</p>
      </div>

      <div class="stat-card">
        <h3>4</h3>
        <p>Major Academic Levels</p>
      </div>

      <div class="stat-card">
        <h3>24/7</h3>
        <p>Digital Access & Support</p>
      </div>

    </div>
  </div>
</section>

<section class="home-cta-section">
  <div class="container">

    <div class="home-cta-card">
      <span>Admissions Open</span>

      <h2>Join Our Educational Community</h2>

      <p>
        Enroll your child today and give them a learning environment built on
        education, discipline and values.
      </p>

      <div class="cta-actions">
        <a href="/admission/process" class="btn-cta">
          Start Admission Process
        </a>

        <a href="/admission/enquiry" class="btn-outline">
          Send Enquiry
        </a>
      </div>
    </div>

  </div>
</section>

