<%- include('../partials/header') %>

<section class="contact-detail-section">
    <div class="container">
        <div class="detail-header">
            <h1>Contact Details</h1>
            <a href="/admin/dashboard" class="btn-back"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
        </div>

        <div class="detail-wrapper">
            <div class="detail-box">
                <div class="detail-row">
                    <div class="detail-field">
                        <label>Name</label>
                        <p><%= contact.name %></p>
                    </div>
                    <div class="detail-field">
                        <label>Email</label>
                        <p><a href="mailto:<%= contact.email %>"><%= contact.email %></a></p>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-field">
                        <label>Phone</label>
                        <p><a href="tel:<%= contact.phone %>"><%= contact.phone %></a></p>
                    </div>
                    <div class="detail-field">
                        <label>Category</label>
                        <p><span class="badge badge-<%= contact.category.toLowerCase() %>"><%= contact.category %></span></p>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-field">
                        <label>Subject</label>
                        <p><%= contact.subject %></p>
                    </div>
                    <div class="detail-field">
                        <label>Status</label>
                        <p>
                            <span class="status-badge status-<%= contact.status %>">
                                <%= contact.status.toUpperCase() %>
                            </span>
                        </p>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-field full-width">
                        <label>Message</label>
                        <p class="message-content"><%= contact.message %></p>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-field">
                        <label>Submitted Date</label>
                        <p><%= new Date(contact.createdAt).toLocaleString('en-IN') %></p>
                    </div>
                </div>

                <div class="detail-actions">
                    <button class="btn-delete" onclick="deleteContact('<%= contact._id %>')">
                        <i class="fas fa-trash"></i> Delete Contact
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .contact-detail-section {
        padding: 60px 0;
        background: #f5f5f5;
    }

    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .detail-header h1 {
        color: #001f3f;
        font-size: 32px;
    }

    .btn-back {
        background: #001f3f;
        color: white;
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 5px;
        transition: 0.3s;
    }

    .btn-back:hover {
        background: #ffc300;
        color: #001f3f;
    }

    .detail-wrapper {
        display: grid;
        grid-template-columns: 1fr;
    }

    .detail-box {
        background: white;
        padding: 40px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .detail-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
        margin-bottom: 30px;
    }

    .detail-row.full-width {
        grid-template-columns: 1fr;
    }

    .detail-field {
        margin-bottom: 0;
    }

    .detail-field label {
        display: block;
        color: #001f3f;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .detail-field p {
        color: #666;
        padding: 12px;
        background: #f5f5f5;
        border-radius: 5px;
        word-break: break-word;
    }

    .detail-field a {
        color: #001f3f;
        text-decoration: none;
    }

    .detail-field a:hover {
        text-decoration: underline;
    }

    .message-content {
        white-space: pre-wrap;
        line-height: 1.6;
    }

    .badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-admission {
        background: #cfe9ff;
        color: #003d82;
    }

    .badge-academic {
        background: #fff3cd;
        color: #856404;
    }

    .badge-general {
        background: #d1e7dd;
        color: #0f5132;
    }

    .badge-complaint {
        background: #f8d7da;
        color: #842029;
    }

    .status-badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-new {
        background: #cfe9ff;
        color: #003d82;
    }

    .status-read {
        background: #fff3cd;
        color: #856404;
    }

    .status-resolved {
        background: #d4edda;
        color: #155724;
    }

    .detail-actions {
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid #eee;
        display: flex;
        gap: 15px;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-delete:hover {
        background: #c82333;
    }

    @media (max-width: 768px) {
        .detail-row {
            grid-template-columns: 1fr;
        }

        .detail-header {
            flex-direction: column;
            gap: 20px;
            align-items: flex-start;
        }
    }
</style>

<script>
    function deleteContact(id) {
        if (confirm('Are you sure you want to delete this contact?')) {
            fetch(`/admin/contact/${id}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Contact deleted successfully');
                    window.location.href = '/admin/dashboard';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error deleting contact');
            });
        }
    }
</script>

<%- include('../partials/footer') %>