<body>
<div class="layout">

  <aside class="sidebar">
   <div class="sidebar-logo">
    <img src="/images/logo.png" alt="Gyan Jyoti Logo">
    <div class="logo-text">
        <h2>Gyan Jyoti</h2>
    </div>
</div>
    <div class="menu">
      <a class="active" href="/admin/dashboard"><i class="fas fa-chart-line"></i> Dashboard</a>
      <a href="#analytics"><i class="fas fa-chart-pie"></i> Analytics</a>
      <a href="#notifications"><i class="fas fa-bell"></i> Notifications</a>
      <a href="#admissions"><i class="fas fa-user-graduate"></i> Admissions</a>
      <a href="#enquiries"><i class="fas fa-phone"></i> Enquiries</a>
      <a href="#contacts"><i class="fas fa-envelope"></i> Contacts</a>
      <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </aside>

  <main class="main">

    <div class="hero">
      <div>
        <h1>Admin Dashboard</h1>
        <p>Welcome back, <%= adminName %> 👋 Manage enquiries, admissions, records and documents here.</p>
      </div>

      <div class="hero-actions">
        <a href="#notifications" class="bell">
          <i class="fas fa-bell"></i> Notifications
          <span><%= notificationCount || 0 %></span>
        </a>
        <button class="theme-toggle" onclick="toggleDarkMode()">
          <i class="fas fa-moon"></i> Dark
        </button>
      </div>
    </div>

    <form method="GET" action="/admin/dashboard" class="search-form">
      <input
        type="text"
        name="keyword"
        placeholder="Search by name, phone, email, class, parent name or message..."
        value="<%= typeof keyword !== 'undefined' ? keyword : '' %>"
      >
      <button type="submit"><i class="fas fa-search"></i> Search</button>
      <% if (typeof keyword !== 'undefined' && keyword) { %>
        <a href="/admin/dashboard" class="clear-btn">Clear</a>
      <% } %>
    </form>

    <div class="cards">
      <div class="card"><i class="fas fa-database"></i><h3 class="counter" data-count="<%= totalCount || 0 %>">0</h3><p>Total Records</p></div>
      <div class="card"><i class="fas fa-envelope-open-text"></i><h3 class="counter" data-count="<%= contactCount || 0 %>">0</h3><p>Contact Messages</p></div>
      <div class="card"><i class="fas fa-comments"></i><h3 class="counter" data-count="<%= enquiryCount || 0 %>">0</h3><p>Enquiries</p></div>
      <div class="card"><i class="fas fa-user-graduate"></i><h3 class="counter" data-count="<%= admissionCount || 0 %>">0</h3><p>Admissions</p></div>
    </div>

    <section id="analytics" class="analytics-grid">
      <div class="chart-card">
        <h2><i class="fas fa-chart-line"></i> Monthly Admissions</h2>
        <canvas id="monthlyAdmissionChart"></canvas>
      </div>

      <div class="chart-card">
        <h2><i class="fas fa-chart-bar"></i> Admission vs Enquiry</h2>
        <canvas id="admissionEnquiryChart"></canvas>
      </div>
    </section>

    <section class="section" id="notifications">
      <div class="section-title">
        <h2><i class="fas fa-bell"></i> Latest Notifications</h2>
        <span class="pill"><%= notificationCount || 0 %> New</span>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Type</th><th>Name</th><th>Contact</th><th>Message</th><th>Date</th><th>Open</th></tr>
          </thead>
          <tbody>
            <% if ((admissions && admissions.length) || (enquiries && enquiries.length) || (contacts && contacts.length)) { %>
              <% admissions.forEach(a => { %>
                <tr>
                  <td><span class="badge admission">Admission</span></td>
                  <td><a class="record-link" href="#admission-<%= a._id %>"><%= a.studentName || '-' %></a></td>
                  <td><%= a.phone || '-' %></td>
                  <td class="message">Class: <%= a.class || '-' %>, Parent: <%= a.parentName || '-' %></td>
                  <td><%= a.createdAt ? new Date(a.createdAt).toLocaleDateString('en-IN') : '-' %></td>
                  <td><a href="#admission-<%= a._id %>" class="action-btn view-btn"><i class="fas fa-arrow-right"></i></a></td>
                </tr>
              <% }) %>

              <% enquiries.forEach(e => { %>
                <tr>
                  <td><span class="badge enquiry">Enquiry</span></td>
                  <td><a class="record-link" href="#enquiry-<%= e._id %>"><%= e.name || '-' %></a></td>
                  <td><%= e.phone || '-' %></td>
                  <td class="message"><%= e.message || '-' %></td>
                  <td><%= e.createdAt ? new Date(e.createdAt).toLocaleDateString('en-IN') : '-' %></td>
                  <td><a href="#enquiry-<%= e._id %>" class="action-btn view-btn"><i class="fas fa-arrow-right"></i></a></td>
                </tr>
              <% }) %>

              <% contacts.forEach(c => { %>
                <tr>
                  <td><span class="badge contact">Contact</span></td>
                  <td><a class="record-link" href="#contact-<%= c._id %>"><%= c.name || '-' %></a></td>
                  <td><%= c.email || '-' %></td>
                  <td class="message"><%= c.subject || '-' %></td>
                  <td><%= c.createdAt ? new Date(c.createdAt).toLocaleDateString('en-IN') : '-' %></td>
                  <td><a href="#contact-<%= c._id %>" class="action-btn view-btn"><i class="fas fa-arrow-right"></i></a></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="6" class="empty">No notifications found</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="section" id="admissions">
      <div class="section-title">
        <h2><i class="fas fa-user-graduate"></i> Registration / Admission Forms</h2>
        <span class="pill"><%= admissionCount || 0 %> Records</span>
      </div>

      <% if (admissions && admissions.length > 0) { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Student</th><th>Class</th><th>Parent</th><th>Phone</th><th>Email</th>
              <th>Address</th><th>Document</th><th>Date</th><th>Type</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% admissions.forEach(a => { %>
            <tr id="admission-<%= a._id %>">
              <td><strong><%= a.studentName || '-' %></strong></td>
              <td><%= a.class || '-' %></td>
              <td><%= a.parentName || '-' %></td>
              <td><%= a.phone || '-' %></td>
              <td><%= a.email || '-' %></td>
              <td class="message"><%= a.address || '-' %></td>

              <td>
                <% if (a.document) { %>
                  <button class="doc-link" onclick="openDocument('/uploads/<%= a.document %>')">
                    <i class="fas fa-folder-open"></i> Preview
                  </button>
                <% } else { %>
                  -
                <% } %>
              </td>

              <td><%= a.createdAt ? new Date(a.createdAt).toLocaleDateString('en-IN') : '-' %></td>
              <td><span class="badge admission">Admission</span></td>
              <td>
                <a href="/admin/admission/edit/<%= a._id %>" class="action-btn edit-btn" title="Edit"><i class="fas fa-edit"></i></a>

                <a href="/admin/admission/delete/<%= a._id %>" class="action-btn delete-btn"
                   onclick="return confirm('Are you sure you want to delete this admission record?')" title="Delete">
                  <i class="fas fa-trash"></i>
                </a>

                <% if (a.document) { %>
                  <a href="/uploads/<%= a.document %>" target="_blank" class="action-btn view-btn" title="Open document">
                    <i class="fas fa-eye"></i>
                  </a>
                <% } %>
<%
  const pdfStudentName = JSON.stringify(a.studentName || '');
  const pdfClassName = JSON.stringify(a.class || '');
  const pdfParentName = JSON.stringify(a.parentName || '');
  const pdfPhone = JSON.stringify(a.phone || '');
  const pdfEmail = JSON.stringify(a.email || '');
  const pdfAddress = JSON.stringify(a.address || '');
  const pdfDate = JSON.stringify(
    a.createdAt ? new Date(a.createdAt).toLocaleDateString("en-IN") : "-"
  );
%>

<button
  type="button"
  class="action-btn pdf-btn"
  title="Print / Save PDF"
  onclick='printAdmission(
    <%- pdfStudentName %>,
    <%- pdfClassName %>,
    <%- pdfParentName %>,
    <%- pdfPhone %>,
    <%- pdfEmail %>,
    <%- pdfAddress %>,
    <%- pdfDate %>
  )'
>
  <i class="fas fa-file-pdf"></i>
</button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
        <div class="empty"><i class="fas fa-folder-open"></i><p>No admission forms yet</p></div>
      <% } %>
    </section>

    <section class="section" id="enquiries">
      <div class="section-title">
        <h2><i class="fas fa-comments"></i> Enquiries</h2>
        <span class="pill"><%= enquiryCount || 0 %> Records</span>
      </div>

      <% if (enquiries && enquiries.length > 0) { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Name</th><th>Phone</th><th>Email</th><th>Message</th><th>Date</th><th>Type</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% enquiries.forEach(e => { %>
            <tr id="enquiry-<%= e._id %>">
              <td><strong><%= e.name || '-' %></strong></td>
              <td><%= e.phone || '-' %></td>
              <td><%= e.email || '-' %></td>
              <td class="message"><%= e.message || '-' %></td>
              <td><%= e.createdAt ? new Date(e.createdAt).toLocaleDateString('en-IN') : '-' %></td>
              <td><span class="badge enquiry">Enquiry</span></td>
              <td>
                <a href="/admin/enquiry/edit/<%= e._id %>" class="action-btn edit-btn" title="Edit"><i class="fas fa-edit"></i></a>
                <a href="/admin/enquiry/delete/<%= e._id %>" class="action-btn delete-btn"
                   onclick="return confirm('Are you sure you want to delete this enquiry?')" title="Delete">
                  <i class="fas fa-trash"></i>
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
        <div class="empty"><i class="fas fa-inbox"></i><p>No enquiries yet</p></div>
      <% } %>
    </section>

    <section class="section" id="contacts">
      <div class="section-title">
        <h2><i class="fas fa-envelope"></i> Contact Submissions</h2>
        <span class="pill"><%= contactCount || 0 %> Records</span>
      </div>

      <% if (contacts && contacts.length > 0) { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Name</th><th>Email</th><th>Category</th><th>Subject</th><th>Date</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% contacts.forEach(c => { %>
            <tr id="contact-<%= c._id %>">
              <td><strong><%= c.name || '-' %></strong></td>
              <td><%= c.email || '-' %></td>
              <td><%= c.category || '-' %></td>
              <td class="message"><%= c.subject || '-' %></td>
              <td><%= c.createdAt ? new Date(c.createdAt).toLocaleDateString('en-IN') : '-' %></td>
              <td><span class="badge contact"><%= c.status || 'new' %></span></td>
              <td>
                <a href="/admin/contact/<%= c._id %>" class="action-btn view-btn" title="View"><i class="fas fa-eye"></i></a>
                <a href="/admin/contact/delete/<%= c._id %>" class="action-btn delete-btn"
                   onclick="return confirm('Are you sure you want to delete this contact?')" title="Delete">
                  <i class="fas fa-trash"></i>
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
        <div class="empty"><i class="fas fa-inbox"></i><p>No contact submissions yet</p></div>
      <% } %>
    </section>

  </main>
</div>

<div class="modal" id="docModal">
  <div class="modal-content">
    <div class="modal-head">
      <h3><i class="fas fa-file"></i> Document Preview</h3>
      <button class="modal-close" onclick="closeDocument()">Close</button>
    </div>
    <div class="modal-body">
      <iframe id="docFrame" src=""></iframe>
    </div>
  </div>
</div>

<script>
  const monthlyLabels = <%- JSON.stringify(typeof monthlyLabels !== 'undefined' ? monthlyLabels : []) %>;
  const monthlyAdmissions = <%- JSON.stringify(typeof monthlyAdmissions !== 'undefined' ? monthlyAdmissions : []) %>;
  const monthlyEnquiries = <%- JSON.stringify(typeof monthlyEnquiries !== 'undefined' ? monthlyEnquiries : []) %>;

  function toggleDarkMode(){
    document.body.classList.toggle('dark-mode');
    localStorage.setItem('adminDarkMode', document.body.classList.contains('dark-mode'));
  }

  if(localStorage.getItem('adminDarkMode') === 'true'){
    document.body.classList.add('dark-mode');
  }

  document.querySelectorAll('.counter').forEach(counter => {
    const target = Number(counter.dataset.count || 0);
    let current = 0;
    const step = Math.max(1, Math.ceil(target / 40));

    const update = () => {
      current += step;
      if(current >= target){
        counter.textContent = target;
      } else {
        counter.textContent = current;
        requestAnimationFrame(update);
      }
    };

    update();
  });

  function openDocument(url){
    document.getElementById('docFrame').src = url;
    document.getElementById('docModal').style.display = 'block';
  }

  function closeDocument(){
    document.getElementById('docFrame').src = '';
    document.getElementById('docModal').style.display = 'none';
  }

  window.onclick = function(event){
    const modal = document.getElementById('docModal');
    if(event.target === modal){
      closeDocument();
    }
  };

  function printAdmission(studentName, className, parentName, phone, email, address, date){
    const content = `
      <html>
      <head>
        <title>Admission Form</title>
        <style>
          body{font-family:Arial;padding:35px;color:#111}
          .box{border:2px solid #001f3f;padding:25px;border-radius:12px}
          h1{text-align:center;color:#001f3f}
          table{width:100%;border-collapse:collapse;margin-top:20px}
          td{padding:12px;border:1px solid #ddd}
          .label{font-weight:bold;background:#f3f4f6;width:220px}
        </style>
      </head>
      <body>
        <div class="box">
          <h1>Gyan Jyoti School</h1>
          <h2>Admission / Registration Form</h2>
          <table>
            <tr><td class="label">Student Name</td><td>${studentName}</td></tr>
            <tr><td class="label">Class</td><td>${className}</td></tr>
            <tr><td class="label">Parent Name</td><td>${parentName}</td></tr>
            <tr><td class="label">Phone</td><td>${phone}</td></tr>
            <tr><td class="label">Email</td><td>${email}</td></tr>
            <tr><td class="label">Address</td><td>${address}</td></tr>
            <tr><td class="label">Submitted Date</td><td>${date}</td></tr>
          </table>
        </div>
      </body>
      </html>
    `;

    const win = window.open('', '_blank');
    win.document.write(content);
    win.document.close();
    win.print();
  }

  const chartLabels = monthlyLabels.length ? monthlyLabels : ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'];
  const chartAdmissions = monthlyAdmissions.length ? monthlyAdmissions : [0, 0, 0, 0, 0, <%= admissionCount || 0 %>];
  const chartEnquiries = monthlyEnquiries.length ? monthlyEnquiries : [0, 0, 0, 0, 0, <%= enquiryCount || 0 %>];

  new Chart(document.getElementById('monthlyAdmissionChart'), {
    type: 'line',
    data: {
      labels: chartLabels,
      datasets: [{
        label: 'Admissions',
        data: chartAdmissions,
        borderWidth: 3,
        tension: .35,
        fill: true
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: true } },
      scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
    }
  });

  new Chart(document.getElementById('admissionEnquiryChart'), {
    type: 'bar',
    data: {
      labels: chartLabels,
      datasets: [
        { label: 'Admissions', data: chartAdmissions },
        { label: 'Enquiries', data: chartEnquiries }
      ]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: true } },
      scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
    }
  });
</script>

</body>
</html>

