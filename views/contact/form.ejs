<%- include('../partials/header') %>

<section class="contact-hero">
  <div class="contact-overlay">
    <div class="contact-container">
      <span class="contact-badge">Get In Touch</span>
      <h1>Contact Us</h1>
      <p><a href="/">Home</a> / Contact Us</p>
    </div>
  </div>
</section>

<section class="contact-main-section">
  <div class="contact-container">

    <div class="contact-heading">
      <span class="section-tag">We Are Here To Help</span>
      <h2>Connect With Gyan Jyoti School</h2>
      <p>
        Have questions about admission, academics, fees, events or school facilities?
        Send us a message and our team will guide you.
      </p>
    </div>

    <div class="contact-grid">

      <div class="contact-info-card">
        <h3>Contact Information</h3>
        <p class="intro-text">Reach out to us through phone, email or visit our school office.</p>

        <div class="info-item">
          <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
          <div>
            <h4>Address</h4>
            <p>
              <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.address ? schoolInfo.address : 'C4M4+858, Ruchika Catering Rd, North Civil Lines, Nainpur, Madhya Pradesh 481776' %>
            </p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
          <div>
            <h4>Phone</h4>
            <p>
              <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.phone ? schoolInfo.phone : '+91 98765-43210' %>
            </p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon"><i class="fas fa-envelope"></i></div>
          <div>
            <h4>Email</h4>
            <p>
              <%= typeof schoolInfo !== 'undefined' && schoolInfo && schoolInfo.email ? schoolInfo.email : 'info@gyanjyoti.com' %>
            </p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon"><i class="fas fa-clock"></i></div>
          <div>
            <h4>Office Hours</h4>
            <p>Monday - Friday: 8:00 AM - 4:00 PM<br>Saturday: 9:00 AM - 1:00 PM</p>
          </div>
        </div>

        <div class="social-box">
          <h4>Follow Us</h4>
          <div class="social-icons">
            <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
            <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
            <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
            <a href="#" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
          </div>
        </div>
      </div>

      <div class="contact-form-card">
        <h3>Send Us a Message</h3>
        <p>Fill out the form below and our team will contact you shortly.</p>

        <% if (typeof success !== 'undefined' && success) { %>
          <div class="success-msg">
            <i class="fas fa-check-circle"></i>
            Your message has been sent successfully.
          </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-msg">
            <i class="fas fa-exclamation-circle"></i>
            Something went wrong. Please fill all details correctly.
          </div>
        <% } %>

        <form action="/contact" method="POST" class="secure-contact-form" novalidate>

          <div class="form-row">
            <div class="form-group">
              <label>Full Name <span>*</span></label>
              <input
                type="text"
                name="name"
                placeholder="Enter your full name"
                pattern="[A-Za-z\s.]{3,60}"
                maxlength="60"
                title="Only letters allowed, minimum 3 characters"
                autocomplete="name"
                required
              >
            </div>

            <div class="form-group">
              <label>Email Address <span>*</span></label>
              <input
                type="email"
                name="email"
                placeholder="your@email.com"
                maxlength="80"
                autocomplete="email"
                required
              >
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Phone Number <span>*</span></label>
              <input
                type="text"
                name="phone"
                placeholder="10 digit mobile number"
                pattern="[0-9]{10}"
                maxlength="10"
                inputmode="numeric"
                title="Enter exactly 10 digits"
                autocomplete="tel"
                required
              >
            </div>

            <div class="form-group">
              <label>Category <span>*</span></label>
              <select name="category" required>
                <option value="">Select Category</option>
                <option value="Admission">Admission</option>
                <option value="Academics">Academics</option>
                <option value="Fees">Fees</option>
                <option value="Transport">Transport</option>
                <option value="Principal Message">Principal Message</option>
                <option value="General">General</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label>Subject <span>*</span></label>
            <input
              type="text"
              name="subject"
              placeholder="Subject of your message"
              minlength="3"
              maxlength="120"
              required
            >
          </div>

          <div class="form-group">
            <label>Message <span>*</span></label>
            <textarea
              name="message"
              placeholder="Write your message here..."
              minlength="5"
              maxlength="1000"
              required
            ></textarea>
            <small class="char-note">
              Max 1000 characters. Scripts and unsafe symbols are not allowed.
            </small>
          </div>

          <button type="submit" class="submit-btn">
            <i class="fas fa-paper-plane"></i> Send Message
          </button>

        </form>
      </div>

    </div>

  </div>
</section>

<section class="connect-section">
  <div class="contact-container">

    <div class="connect-card">

      <div class="connect-left">
        <span class="section-tag">Visit & Connect</span>
        <h2>Start Your Journey With Gyan Jyoti</h2>
        <p>
          Admission enquiry, school visit, parent meeting or general support —
          our team is ready to guide you with the right information.
        </p>

        <div class="connect-actions">
          <a href="/admission/enquiry"><i class="fas fa-paper-plane"></i> Admission Enquiry</a>
          <a href="/admission/registration"><i class="fas fa-user-plus"></i> Register Now</a>
          <a href="tel:+919876543210"><i class="fas fa-phone"></i> Call School</a>
        </div>
      </div>

      <div class="connect-right">
        <div class="mini-card">
          <i class="fas fa-clock"></i>
          <h3>Office Hours</h3>
          <p>Mon - Fri: 8:00 AM - 4:00 PM<br>Sat: 9:00 AM - 1:00 PM</p>
        </div>

        <div class="mini-card">
          <i class="fas fa-location-dot"></i>
          <h3>Campus Visit</h3>
          <p>Parents can visit the school office for admission guidance and support.</p>
        </div>

        <div class="mini-card">
          <i class="fas fa-headset"></i>
          <h3>Quick Support</h3>
          <p>Our team responds to admission, contact and enquiry messages quickly.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .contact-container {
    width: 86%;
    max-width: 1200px;
    margin: auto;
  }

  .contact-hero {
    height: 420px;
    background:
      linear-gradient(rgba(0,31,63,.78), rgba(0,31,63,.78)),
      url('/images/school-bg.jpg');
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
  }

  .contact-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,195,0,.35) 2px, transparent 2px),
      radial-gradient(circle, rgba(255,255,255,.14) 1px, transparent 1px);
    background-size: 120px 120px, 75px 75px;
    animation: contactDots 22s linear infinite;
  }

  @keyframes contactDots {
    from { transform: translateY(0); }
    to { transform: translateY(-120px); }
  }

  .contact-overlay {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .contact-badge,
  .section-tag {
    display: inline-block;
    background: #ffc300;
    color: #001f3f;
    padding: 9px 22px;
    border-radius: 40px;
    font-weight: 900;
    margin-bottom: 15px;
  }

  .contact-hero h1 {
    color: white;
    font-size: 64px;
    font-weight: 900;
    text-shadow: 0 15px 35px rgba(0,0,0,.38);
  }

  .contact-hero p,
  .contact-hero a {
    color: white;
    font-size: 18px;
    margin-top: 8px;
  }

  .contact-main-section {
    padding: 85px 0;
    background: #f5f7fb;
  }

  .contact-heading {
    text-align: center;
    margin-bottom: 55px;
  }

  .contact-heading h2 {
    font-size: 46px;
    color: #001f3f;
    margin-bottom: 15px;
  }

  .contact-heading p {
    max-width: 800px;
    margin: auto;
    color: #555;
    font-size: 18px;
    line-height: 1.7;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: .9fr 1.1fr;
    gap: 40px;
    align-items: stretch;
  }

  .contact-info-card,
  .contact-form-card {
    background: white;
    border-radius: 30px;
    padding: 42px;
    box-shadow: 0 22px 55px rgba(0,0,0,.13);
    position: relative;
    overflow: hidden;
  }

  .contact-info-card {
    background: linear-gradient(135deg, #001f3f, #004481);
    color: white;
  }

  .contact-info-card::after,
  .contact-form-card::after {
    content: "";
    position: absolute;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: rgba(255,195,0,.12);
    right: -120px;
    top: -120px;
  }

  .contact-info-card > *,
  .contact-form-card > * {
    position: relative;
    z-index: 2;
  }

  .contact-info-card h3,
  .contact-form-card h3 {
    font-size: 32px;
    margin-bottom: 12px;
    color: #001f3f;
  }

  .contact-info-card h3 {
    color: #ffc300;
  }

  .intro-text,
  .contact-form-card > p {
    color: #555;
    margin-bottom: 28px;
    font-size: 17px;
    line-height: 1.7;
  }

  .contact-info-card .intro-text {
    color: rgba(255,255,255,.9);
  }

  .info-item {
    display: flex;
    gap: 18px;
    margin-bottom: 26px;
  }

  .info-icon {
    min-width: 52px;
    height: 52px;
    background: #ffc300;
    color: #001f3f;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    box-shadow: 0 10px 25px rgba(255,195,0,.3);
  }

  .info-item h4 {
    color: white;
    font-size: 19px;
    margin-bottom: 6px;
  }

  .info-item p {
    color: rgba(255,255,255,.88);
    line-height: 1.6;
  }

  .social-box {
    margin-top: 25px;
    padding-top: 25px;
    border-top: 1px solid rgba(255,255,255,.18);
  }

  .social-box h4 {
    color: white;
    margin-bottom: 16px;
  }

  .social-icons {
    display: flex;
    gap: 12px;
  }

  .social-icons a {
    width: 44px;
    height: 44px;
    background: #ffc300;
    color: #001f3f;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: .35s;
  }

  .social-icons a:hover {
    background: white;
    transform: translateY(-5px);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .form-group {
    margin-bottom: 18px;
  }

  .form-group label {
    display: block;
    color: #001f3f;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .form-group span {
    color: #dc2626;
  }

  .contact-form-card input,
  .contact-form-card select,
  .contact-form-card textarea {
    width: 100%;
    padding: 15px 18px;
    border: 1px solid #d1d5db;
    border-radius: 14px;
    font-size: 15px;
    outline: none;
    transition: .3s;
    background: white;
  }

  .contact-form-card textarea {
    height: 160px;
    resize: none;
  }

  .contact-form-card input:focus,
  .contact-form-card select:focus,
  .contact-form-card textarea:focus {
    border-color: #ffc300;
    box-shadow: 0 0 0 4px rgba(255,195,0,.22);
  }

  .char-note {
    display: block;
    margin-top: 7px;
    color: #666;
    font-size: 13px;
  }

  .submit-btn {
    border: none;
    background: linear-gradient(135deg, #ffc300, #ffdd55);
    color: #001f3f;
    padding: 16px 32px;
    border-radius: 50px;
    font-weight: 900;
    cursor: pointer;
    font-size: 15px;
    box-shadow: 0 12px 28px rgba(255,195,0,.35);
    transition: .35s;
  }

  .submit-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 35px rgba(255,195,0,.45);
  }

  .submit-btn:disabled {
    opacity: .7;
    cursor: not-allowed;
  }

  .success-msg {
    background: #d1e7dd;
    color: #0f5132;
    padding: 13px;
    border-radius: 12px;
    margin-bottom: 18px;
    font-weight: 800;
  }

  .error-msg {
    background: #f8d7da;
    color: #842029;
    padding: 13px;
    border-radius: 12px;
    margin-bottom: 18px;
    font-weight: 800;
  }

  .connect-section {
    padding: 85px 0;
    background:
      linear-gradient(135deg, rgba(0,31,63,.96), rgba(0,68,129,.94)),
      url('/images/school-bg.jpg');
    background-size: cover;
    background-position: center;
  }

  .connect-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 35px;
    align-items: center;
  }

  .connect-left {
    color: white;
  }

  .connect-left h2 {
    color: white;
    font-size: 48px;
    line-height: 1.15;
    margin-bottom: 18px;
  }

  .connect-left p {
    font-size: 18px;
    line-height: 1.8;
    opacity: .92;
    margin-bottom: 28px;
  }

  .connect-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }

  .connect-actions a {
    background: #ffc300;
    color: #001f3f;
    padding: 14px 22px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 900;
    transition: .35s;
    box-shadow: 0 12px 28px rgba(255,195,0,.28);
  }

  .connect-actions a:hover {
    transform: translateY(-5px);
    background: white;
  }

  .connect-right {
    display: grid;
    gap: 20px;
  }

  .mini-card {
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.20);
    backdrop-filter: blur(10px);
    padding: 26px;
    border-radius: 24px;
    color: white;
    transition: .35s;
  }

  .mini-card:hover {
    transform: translateX(-10px);
    background: rgba(255,255,255,.18);
  }

  .mini-card i {
    color: #ffc300;
    font-size: 34px;
    margin-bottom: 14px;
  }

  .mini-card h3 {
    color: white;
    font-size: 23px;
    margin-bottom: 8px;
  }

  .mini-card p {
    opacity: .9;
    line-height: 1.6;
  }

  @media(max-width: 900px) {
    .contact-grid,
    .form-row,
    .connect-card {
      grid-template-columns: 1fr;
    }

    .contact-hero h1 {
      font-size: 42px;
    }

    .contact-heading h2,
    .connect-left h2 {
      font-size: 34px;
    }
  }
</style>

<script>
  const contactForm = document.querySelector('.secure-contact-form');

  if (contactForm) {
    contactForm.addEventListener('submit', function(e) {
      const name = this.name.value.trim();
      const email = this.email.value.trim();
      const phone = this.phone.value.trim();
      const category = this.category.value.trim();
      const subject = this.subject.value.trim();
      const message = this.message.value.trim();

      const nameRegex = /^[A-Za-z\s.]{3,60}$/;
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const unsafeRegex = /<script|<\/script|javascript:|onerror=|onload=|<iframe|<\/iframe/gi;

      if (!nameRegex.test(name)) {
        alert('Full name should contain only letters and minimum 3 characters.');
        e.preventDefault();
        return;
      }

      if (!emailRegex.test(email)) {
        alert('Please enter a valid email address.');
        e.preventDefault();
        return;
      }

      if (!/^[0-9]{10}$/.test(phone)) {
        alert('Phone number must be exactly 10 digits.');
        e.preventDefault();
        return;
      }

      if (!category) {
        alert('Please select a category.');
        e.preventDefault();
        return;
      }

      if (subject.length < 3 || subject.length > 120 || unsafeRegex.test(subject)) {
        alert('Please enter a valid subject.');
        e.preventDefault();
        return;
      }

      if (message.length < 5 || message.length > 1000 || unsafeRegex.test(message)) {
        alert('Please enter a valid message. Unsafe script text is not allowed.');
        e.preventDefault();
        return;
      }

      const btn = this.querySelector('.submit-btn');
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
      btn.disabled = true;
    });
  }
</script>

<%- include('../partials/footer') %>