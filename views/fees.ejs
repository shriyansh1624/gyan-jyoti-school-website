<%- include('partials/header') %>

<section class="fees-hero">
  <div class="fees-container">
    <img src="/images/logo.png" class="fees-logo" alt="Gyan Jyoti Logo">
    <span class="fees-badge">Session 2026-27</span>
    <h1>Fees Structure</h1>
    <p>Class-wise fee details with separate PDF download options.</p>
  </div>
</section>

<section class="fees-section">
  <div class="fees-container">

    <div class="fees-heading">
      <span class="section-tag">Class Wise Fees</span>
      <h2>Transparent Fee Structure</h2>
      <p>Choose a section and download only that section’s fee structure.</p>
    </div>

    <div class="fees-grid">

      <div class="fees-card" id="primary-fees">
        <div class="fees-head">
          <i class="fas fa-child"></i>
          <h3>Primary</h3>
          <p>Class 1st to 5th</p>
        </div>

        <table>
          <tr><td>Admission Fee</td><td>₹ 3,000</td></tr>
          <tr><td>Monthly Tuition Fee</td><td>₹ 900</td></tr>
          <tr><td>Exam Fee</td><td>₹ 1,000</td></tr>
          <tr><td>Activity Fee</td><td>₹ 800</td></tr>
          <tr class="total"><td>Annual Approx.</td><td>₹ 15,600</td></tr>
        </table>

        <button onclick="downloadSection('primary-fees')">
          <i class="fas fa-file-pdf"></i> Download Primary PDF
        </button>
      </div>

      <div class="fees-card" id="middle-fees">
        <div class="fees-head">
          <i class="fas fa-book-reader"></i>
          <h3>Middle</h3>
          <p>Class 6th to 8th</p>
        </div>

        <table>
          <tr><td>Admission Fee</td><td>₹ 3,500</td></tr>
          <tr><td>Monthly Tuition Fee</td><td>₹ 1,100</td></tr>
          <tr><td>Exam Fee</td><td>₹ 1,200</td></tr>
          <tr><td>Activity Fee</td><td>₹ 1,000</td></tr>
          <tr class="total"><td>Annual Approx.</td><td>₹ 18,900</td></tr>
        </table>

        <button onclick="downloadSection('middle-fees')">
          <i class="fas fa-file-pdf"></i> Download Middle PDF
        </button>
      </div>

      <div class="fees-card" id="secondary-fees">
        <div class="fees-head">
          <i class="fas fa-user-graduate"></i>
          <h3>Secondary</h3>
          <p>Class 9th to 10th</p>
        </div>

        <table>
          <tr><td>Admission Fee</td><td>₹ 4,000</td></tr>
          <tr><td>Monthly Tuition Fee</td><td>₹ 1,300</td></tr>
          <tr><td>Exam Fee</td><td>₹ 1,500</td></tr>
          <tr><td>Lab / Activity Fee</td><td>₹ 1,200</td></tr>
          <tr class="total"><td>Annual Approx.</td><td>₹ 22,300</td></tr>
        </table>

        <button onclick="downloadSection('secondary-fees')">
          <i class="fas fa-file-pdf"></i> Download 9th-10th PDF
        </button>
      </div>

      <div class="fees-card" id="senior-fees">
        <div class="fees-head">
          <i class="fas fa-graduation-cap"></i>
          <h3>Senior Secondary</h3>
          <p>Class 11th to 12th</p>
        </div>

        <table>
          <tr><td>Admission Fee</td><td>₹ 5,000</td></tr>
          <tr><td>Monthly Tuition Fee</td><td>₹ 1,600</td></tr>
          <tr><td>Exam Fee</td><td>₹ 1,800</td></tr>
          <tr><td>Lab / Practical Fee</td><td>₹ 2,000</td></tr>
          <tr class="total"><td>Annual Approx.</td><td>₹ 28,000</td></tr>
        </table>

        <button onclick="downloadSection('senior-fees')">
          <i class="fas fa-file-pdf"></i> Download 11th-12th PDF
        </button>
      </div>

    </div>

    <div class="fees-note">
      <h3><i class="fas fa-circle-info"></i> Important Notes</h3>
      <p>Transport, uniform and books charges may be separate. Please contact school office for final confirmation.</p>
    </div>

  </div>
</section>

<style>
  .fees-container{width:86%;max-width:1200px;margin:auto}

  .fees-hero{
    min-height:460px;
    background:linear-gradient(rgba(0,31,63,.84),rgba(0,31,63,.84)),url('/images/school-bg.jpg');
    background-size:cover;
    background-position:center;
    display:flex;
    align-items:center;
    text-align:center;
    color:white;
    position:relative;
    overflow:hidden;
  }

  .fees-hero::after{
    content:"";
    position:absolute;
    inset:0;
    background-image:radial-gradient(circle,rgba(255,195,0,.35) 2px,transparent 2px);
    background-size:110px 110px;
    animation:moveDots 20s linear infinite;
  }

  @keyframes moveDots{
    from{transform:translateY(0)}
    to{transform:translateY(-110px)}
  }

  .fees-hero .fees-container{position:relative;z-index:2}

  .fees-logo{
    width:125px;
    height:125px;
    object-fit:contain;
    background:white;
    border-radius:50%;
    padding:8px;
    border:5px solid #ffc300;
    box-shadow:0 18px 45px rgba(0,0,0,.35);
    margin-bottom:18px;
  }

  .fees-badge,.section-tag{
    display:inline-block;
    background:#ffc300;
    color:#001f3f;
    padding:9px 22px;
    border-radius:40px;
    font-weight:900;
    margin-bottom:15px;
  }

  .fees-hero h1{
    font-size:66px;
    font-weight:900;
    color:white;
    text-shadow:0 15px 35px rgba(0,0,0,.4);
  }

  .fees-hero p{
    font-size:20px;
    margin-top:12px;
  }

  .fees-section{
    padding:85px 0;
    background:#f5f7fb;
  }

  .fees-heading{
    text-align:center;
    margin-bottom:55px;
  }

  .fees-heading h2{
    font-size:46px;
    color:#001f3f;
    margin-bottom:12px;
  }

  .fees-heading p{
    color:#555;
    font-size:18px;
  }

  .fees-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:32px;
  }

  .fees-card{
    background:white;
    border-radius:30px;
    overflow:hidden;
    box-shadow:0 22px 55px rgba(0,0,0,.13);
    border-top:6px solid #ffc300;
    transition:.4s;
    position:relative;
  }

  .fees-card:hover{
    transform:translateY(-12px);
    box-shadow:0 32px 70px rgba(0,0,0,.2);
  }

  .fees-card::after{
    content:"";
    position:absolute;
    width:250px;
    height:250px;
    right:-130px;
    top:-130px;
    background:rgba(255,195,0,.12);
    border-radius:50%;
  }

  .fees-head{
    background:linear-gradient(135deg,#001f3f,#004481);
    color:white;
    padding:32px;
    text-align:center;
    position:relative;
    z-index:2;
  }

  .fees-head i{
    color:#ffc300;
    font-size:46px;
    margin-bottom:15px;
  }

  .fees-head h3{
    color:white;
    font-size:32px;
    margin-bottom:6px;
  }

  .fees-head p{
    opacity:.9;
  }

  .fees-card table{
    width:100%;
    border-collapse:collapse;
    position:relative;
    z-index:2;
  }

  .fees-card td{
    padding:16px 24px;
    border-bottom:1px solid #eef2f7;
    font-weight:700;
    color:#333;
  }

  .fees-card td:last-child{
    text-align:right;
    color:#001f3f;
    font-weight:900;
  }

  .fees-card .total td{
    background:#ffc300;
    color:#001f3f;
    font-size:18px;
    font-weight:900;
  }

  .fees-card button{
    margin:24px;
    border:none;
    background:linear-gradient(135deg,#001f3f,#004481);
    color:white;
    padding:14px 22px;
    border-radius:50px;
    font-weight:900;
    cursor:pointer;
    box-shadow:0 12px 28px rgba(0,31,63,.22);
    transition:.35s;
    position:relative;
    z-index:2;
  }

  .fees-card button:hover{
    background:#ffc300;
    color:#001f3f;
    transform:translateY(-4px);
  }

  .fees-note{
    margin-top:45px;
    background:white;
    padding:35px;
    border-radius:26px;
    box-shadow:0 16px 40px rgba(0,0,0,.10);
    border-left:7px solid #ffc300;
  }

  .fees-note h3{
    color:#001f3f;
    font-size:26px;
    margin-bottom:12px;
  }

  .fees-note i{
    color:#ffc300;
  }

  .fees-note p{
    color:#444;
    font-size:17px;
    line-height:1.7;
  }

  @media(max-width:900px){
    .fees-grid{grid-template-columns:1fr}
    .fees-hero h1{font-size:42px}
    .fees-heading h2{font-size:34px}
  }
</style>

<script>
  function downloadSection(sectionId){
    const section = document.getElementById(sectionId).cloneNode(true);
    const button = section.querySelector('button');
    if(button) button.remove();

    const printWindow = window.open('', '_blank');

    printWindow.document.write(`
      <html>
      <head>
        <title>Fees Structure</title>
        <style>
          body{font-family:Arial;padding:35px;color:#111}
          .print-header{text-align:center;margin-bottom:25px}
          .print-header img{width:90px;height:90px;object-fit:contain}
          .print-header h1{color:#001f3f;margin:10px 0 4px}
          .fees-card{border:2px solid #001f3f;border-radius:16px;overflow:hidden}
          .fees-head{background:#001f3f;color:white;text-align:center;padding:22px}
          .fees-head i{display:none}
          .fees-head h3{font-size:28px;margin:0;color:white}
          .fees-head p{margin:6px 0 0}
          table{width:100%;border-collapse:collapse}
          td{padding:14px 18px;border:1px solid #ddd;font-weight:bold}
          td:last-child{text-align:right;color:#001f3f}
          .total td{background:#ffc300;color:#001f3f;font-size:18px}
          .note{margin-top:20px;font-size:14px;color:#444}
        </style>
      </head>
      <body>
        <div class="print-header">
          <img src="/images/logo.png">
          <h1>Gyan Jyoti School</h1>
          <p>Fees Structure - Session 2026-27</p>
        </div>

        ${section.outerHTML}

        <p class="note">
          Note: Transport, uniform and books charges may be separate.
          Please contact school office for final confirmation.
        </p>
      </body>
      </html>
    `);

    printWindow.document.close();
    printWindow.focus();

    setTimeout(() => {
      printWindow.print();
    }, 500);
  }
</script>

<%- include('partials/footer') %>